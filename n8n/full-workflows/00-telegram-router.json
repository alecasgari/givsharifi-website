{
  "name": "GivSharifi — 00 Telegram Router",
  "nodes": [
    {
      "parameters": {
        "updates": [
          "message",
          "callback_query"
        ]
      },
      "id": "b8c755d5-1dc7-42eb-90c5-1eb169e372e8",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "7817acc6-326d-4b27-8700-40d8bf875cd4",
              "leftValue": "={{ String($json.message?.chat?.id || $json.callback_query?.message?.chat?.id) }}",
              "rightValue": "={{ $env.GIV_TELEGRAM_ALLOWED_CHAT_ID }}",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "91075ac8-edb7-4d3f-a83e-fcec217b836e",
      "name": "Authorized chat?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        220,
        0
      ]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.message?.text || '' }}",
                    "rightValue": "/start",
                    "operator": {
                      "type": "string",
                      "operation": "startsWith"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "start"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.message?.photo ? 'yes' : 'no' }}",
                    "rightValue": "yes",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "photo"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.message?.text || '' }}",
                    "rightValue": "instagram.com",
                    "operator": {
                      "type": "string",
                      "operation": "contains"
                    }
                  },
                  {
                    "leftValue": "={{ $json.message?.text || '' }}",
                    "rightValue": "youtube.com",
                    "operator": {
                      "type": "string",
                      "operation": "contains"
                    }
                  },
                  {
                    "leftValue": "={{ $json.message?.text || '' }}",
                    "rightValue": "youtu.be",
                    "operator": {
                      "type": "string",
                      "operation": "contains"
                    }
                  }
                ],
                "combinator": "or"
              },
              "renameOutput": true,
              "outputKey": "video"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.message?.text || '' }}",
                    "rightValue": "/blog",
                    "operator": {
                      "type": "string",
                      "operation": "startsWith"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "blog"
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      },
      "id": "e6fc06e4-b53e-4270-b825-a75e13eb5dd2",
      "name": "Route message type",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [
        440,
        0
      ]
    },
    {
      "parameters": {
        "chatId": "={{ $json.message.chat.id }}",
        "text": "Prof. Giv Sharifi — Content Bot\n\n📷 Send a photo → gallery\n🎬 Send Instagram reel or YouTube link → videos\n📝 Send /blog then your draft text\n\nImages → GitHub | Videos → Cloudflare R2",
        "replyMarkup": "inlineKeyboard",
        "inlineKeyboard": {
          "rows": [
            [
              {
                "text": "📷 Photo help",
                "callback_data": "help_photo"
              }
            ],
            [
              {
                "text": "🎬 Video help",
                "callback_data": "help_video"
              }
            ],
            [
              {
                "text": "📝 Blog help",
                "callback_data": "help_blog"
              }
            ]
          ]
        }
      },
      "id": "280fae61-1217-4e3c-b655-f4c93aaf4234",
      "name": "Send menu",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        660,
        -200
      ]
    },
    {
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            {
              "id": "85dbcbba-d415-43df-9c39-300e345dabdf",
              "name": "chat_id",
              "value": "={{ $json.message.chat.id }}",
              "type": "number"
            },
            {
              "id": "80c36e9b-b719-4687-a55e-29cdbc8b11b6",
              "name": "photo_file_id",
              "value": "={{ $json.message.photo.slice(-1)[0].file_id }}",
              "type": "string"
            },
            {
              "id": "f0492cc3-aff5-4c7a-b36b-4e252908be1d",
              "name": "caption",
              "value": "={{ $json.message.caption || '' }}",
              "type": "string"
            }
          ]
        }
      },
      "id": "eda3403a-49aa-47c0-a31d-b05ae2a0f3b0",
      "name": "Prepare photo payload",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        660,
        0
      ]
    },
    {
      "parameters": {
        "workflowId": "={{ $env.GIV_WF_PHOTO_ID }}",
        "mode": "each",
        "options": {}
      },
      "id": "30cfa72a-0b64-4c2b-a10c-d4f1aa6d4d82",
      "name": "Run publish photo",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.2,
      "position": [
        880,
        0
      ],
      "notes": "After import: set GIV_WF_PHOTO_ID to workflow ID of 01-publish-photo"
    },
    {
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            {
              "id": "a8f7895d-80ab-404d-9176-7b9a99111402",
              "name": "chat_id",
              "value": "={{ $json.message.chat.id }}",
              "type": "number"
            },
            {
              "id": "aaf3afa2-0854-499e-b65a-57927b2edae1",
              "name": "video_url",
              "value": "={{ $json.message.text.trim() }}",
              "type": "string"
            }
          ]
        }
      },
      "id": "21001a86-47f1-4d8e-a372-7d1a33b9e081",
      "name": "Prepare video payload",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        660,
        160
      ]
    },
    {
      "parameters": {
        "workflowId": "={{ $env.GIV_WF_VIDEO_ID }}",
        "mode": "each",
        "options": {}
      },
      "id": "27f6bf71-29c4-4d88-92b6-fd52f06ba4cd",
      "name": "Run publish video",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.2,
      "position": [
        880,
        160
      ],
      "notes": "Set GIV_WF_VIDEO_ID after import"
    },
    {
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            {
              "id": "e5334f56-d227-41fb-85bd-68bb3b6df3fd",
              "name": "chat_id",
              "value": "={{ $json.message.chat.id }}",
              "type": "number"
            },
            {
              "id": "e1422546-5888-49f0-9ebf-9a2f2a9e076c",
              "name": "draft_text",
              "value": "={{ $json.message.text.replace(/^\\/blog\\s*/i, '').trim() }}",
              "type": "string"
            },
            {
              "id": "be4fe150-6740-46f5-b3d8-fc334ae46d1e",
              "name": "photo_file_id",
              "value": "={{ $json.message.photo ? $json.message.photo.slice(-1)[0].file_id : '' }}",
              "type": "string"
            }
          ]
        }
      },
      "id": "8ea138a8-cbcb-4b59-848f-7934f658cc9f",
      "name": "Prepare blog payload",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        660,
        320
      ]
    },
    {
      "parameters": {
        "workflowId": "={{ $env.GIV_WF_BLOG_ID }}",
        "mode": "each",
        "options": {}
      },
      "id": "79cbde7a-fa86-4a20-8a4d-6451b269f514",
      "name": "Run publish blog",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.2,
      "position": [
        880,
        320
      ],
      "notes": "Set GIV_WF_BLOG_ID after import"
    },
    {
      "parameters": {
        "chatId": "={{ $json.message.chat.id }}",
        "text": "Send:\n• Photo (with optional caption)\n• Instagram reel or YouTube link\n• /blog Your article draft…"
      },
      "id": "31f8d8d2-74cf-43d5-8490-3f0f159fb204",
      "name": "Send help",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        660,
        480
      ]
    },
    {
      "parameters": {
        "chatId": "={{ $json.message?.chat?.id || $json.callback_query?.message?.chat?.id }}",
        "text": "Unauthorized."
      },
      "id": "6540df25-7827-4b29-ab2d-09c35fd46a05",
      "name": "Unauthorized",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        440,
        200
      ]
    },
    {
      "parameters": {
        "content": "## Telegram router\nImport sub-workflows first. Copy their workflow IDs into env vars:\n`GIV_WF_PHOTO_ID`, `GIV_WF_VIDEO_ID`, `GIV_WF_BLOG_ID`\n\nOr replace Execute Workflow nodes with manual workflow picker after import."
      },
      "id": "7674fe29-d611-480c-97de-0388d30279c4",
      "name": "Note: Router",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -40,
        -220
      ]
    }
  ],
