{
  "name": "GivSharifi — 00 Telegram Router",
  "nodes": [
    {
      "parameters": {
        "updates": [
          "message",
          "callback_query"
        ]
      },
      "id": "aedc1fd9-7764-4865-8ed6-00734d0b7f8d",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "2ace71cd-495e-4baa-a844-6b58d5c588f1",
              "leftValue": "={{ String($json.message?.chat?.id || $json.callback_query?.message?.chat?.id) }}",
              "rightValue": "={{ $env.GIV_TELEGRAM_ALLOWED_CHAT_ID }}",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "4096a4ef-3947-4cda-9d26-11b4ad949304",
      "name": "Authorized chat?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        220,
        0
      ]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.message?.text || '' }}",
                    "rightValue": "/start",
                    "operator": {
                      "type": "string",
                      "operation": "startsWith"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "start"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.message?.photo ? 'yes' : 'no' }}",
                    "rightValue": "yes",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "photo"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.message?.text || '' }}",
                    "rightValue": "instagram.com",
                    "operator": {
                      "type": "string",
                      "operation": "contains"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "video"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.message?.text || '' }}",
                    "rightValue": "/blog",
                    "operator": {
                      "type": "string",
                      "operation": "startsWith"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "blog"
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      },
      "id": "24322583-8c4d-45a8-b1d1-041a9cdb150c",
      "name": "Route message type",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [
        440,
        0
      ]
    },
    {
      "parameters": {
        "chatId": "={{ $json.message.chat.id }}",
        "text": "Prof. Giv Sharifi — Content Bot\n\n📷 Send a photo → gallery\n🎬 Send Instagram reel URL → videos\n📝 Send /blog then your draft text\n\nImages → GitHub | Videos → Cloudflare R2",
        "replyMarkup": "inlineKeyboard",
        "inlineKeyboard": {
          "rows": [
            [
              {
                "text": "📷 Photo help",
                "callback_data": "help_photo"
              }
            ],
            [
              {
                "text": "🎬 Video help",
                "callback_data": "help_video"
              }
            ],
            [
              {
                "text": "📝 Blog help",
                "callback_data": "help_blog"
              }
            ]
          ]
        }
      },
      "id": "3c42a89a-f8dc-4bd4-a677-4cb792ff8629",
      "name": "Send menu",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        660,
        -200
      ]
    },
    {
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            {
              "id": "2d157c51-5e7a-43a1-a3e7-93a534f5fa69",
              "name": "chat_id",
              "value": "={{ $json.message.chat.id }}",
              "type": "number"
            },
            {
              "id": "aa743d0e-11bf-4b0e-8e0e-6b9764d5fd07",
              "name": "photo_file_id",
              "value": "={{ $json.message.photo.slice(-1)[0].file_id }}",
              "type": "string"
            },
            {
              "id": "f3087f5c-ebe3-490d-92d5-ee6afaffc149",
              "name": "caption",
              "value": "={{ $json.message.caption || '' }}",
              "type": "string"
            }
          ]
        }
      },
      "id": "82f9ffa7-adc9-4e6b-91b5-1b3dd9a2d97b",
      "name": "Prepare photo payload",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        660,
        0
      ]
    },
    {
      "parameters": {
        "workflowId": "={{ $env.GIV_WF_PHOTO_ID }}",
        "mode": "each",
        "options": {}
      },
      "id": "d1588653-7dfe-4a15-bdd3-e7cd22463034",
      "name": "Run publish photo",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.2,
      "position": [
        880,
        0
      ],
      "notes": "After import: set GIV_WF_PHOTO_ID to workflow ID of 01-publish-photo"
    },
    {
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            {
              "id": "0b8050fe-097e-431a-96e9-942ef45b8794",
              "name": "chat_id",
              "value": "={{ $json.message.chat.id }}",
              "type": "number"
            },
            {
              "id": "79b9f404-53aa-4f90-bf5d-02850b4564c2",
              "name": "reel_url",
              "value": "={{ $json.message.text.trim() }}",
              "type": "string"
            }
          ]
        }
      },
      "id": "f80eb73f-6f34-4b0c-9d91-c8cbccf3548a",
      "name": "Prepare video payload",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        660,
        160
      ]
    },
    {
      "parameters": {
        "workflowId": "={{ $env.GIV_WF_VIDEO_ID }}",
        "mode": "each",
        "options": {}
      },
      "id": "841972c7-d034-4801-b8c2-2a18f0a6b42a",
      "name": "Run publish video",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.2,
      "position": [
        880,
        160
      ],
      "notes": "Set GIV_WF_VIDEO_ID after import"
    },
    {
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            {
              "id": "5ea9f808-f8b3-438b-a732-cb3043aaf5f3",
              "name": "chat_id",
              "value": "={{ $json.message.chat.id }}",
              "type": "number"
            },
            {
              "id": "9bb52119-dbfc-4d3d-8512-d43494a31b89",
              "name": "draft_text",
              "value": "={{ $json.message.text.replace(/^\\/blog\\s*/i, '').trim() }}",
              "type": "string"
            },
            {
              "id": "bcd0a9a4-3baa-48bd-9402-f2ad543862fd",
              "name": "photo_file_id",
              "value": "={{ $json.message.photo ? $json.message.photo.slice(-1)[0].file_id : '' }}",
              "type": "string"
            }
          ]
        }
      },
      "id": "b1b408d1-b7a3-42cb-ada9-c5fabfff6677",
      "name": "Prepare blog payload",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        660,
        320
      ]
    },
    {
      "parameters": {
        "workflowId": "={{ $env.GIV_WF_BLOG_ID }}",
        "mode": "each",
        "options": {}
      },
      "id": "e16fa0fa-901a-491f-9e46-983f53f4020e",
      "name": "Run publish blog",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.2,
      "position": [
        880,
        320
      ],
      "notes": "Set GIV_WF_BLOG_ID after import"
    },
    {
      "parameters": {
        "chatId": "={{ $json.message.chat.id }}",
        "text": "Send:\n• Photo (with optional caption)\n• Instagram reel link\n• /blog Your article draft…"
      },
      "id": "1270f342-f4a4-4879-8552-d8f7b6cc9b43",
      "name": "Send help",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        660,
        480
      ]
    },
    {
      "parameters": {
        "chatId": "={{ $json.message?.chat?.id || $json.callback_query?.message?.chat?.id }}",
        "text": "Unauthorized."
      },
      "id": "466545ee-4ed5-47be-98c8-56095348203b",
      "name": "Unauthorized",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
