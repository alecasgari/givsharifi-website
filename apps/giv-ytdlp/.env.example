# HTTP server (inside Docker — not exposed to the public internet)
GIV_YTDLP_HOST=0.0.0.0
GIV_YTDLP_PORT=9876

# Optional shared secret — n8n must send {"token": "..."} if set
GIV_YTDLP_TOKEN=

# Temp download directory (mounted volume in Docker)
GIV_YTDLP_DATA_DIR=/data

# Cloudflare R2 (S3-compatible) — required for production with n8n in Docker
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=givsharifi-videos
R2_PREFIX=library
R2_PUBLIC_BASE_URL=https://media.givsharifi.com

# Optional: path inside container to Netscape cookies.txt for Instagram
# GIV_YTDLP_COOKIES_FILE=/data/cookies.txt
