# Copy to .env on the server (or run setup-on-server.sh).
# Note: dotfiles like .env.example are often skipped by scp — this file is env.example on purpose.

GIV_YTDLP_HOST=0.0.0.0
GIV_YTDLP_PORT=9876
GIV_YTDLP_TOKEN=
GIV_YTDLP_DATA_DIR=/data

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=givsharifi-videos
R2_PREFIX=library
R2_PUBLIC_BASE_URL=https://media.givsharifi.com
